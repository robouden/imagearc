#!/usr/bin/env bash
# ImageArc — caption the selected photos/folders and write IPTC/XMP keywords,
# so Shotwell (and Lightroom, digiKam, darktable…) can read them as tags.
#
# Opens a terminal window showing live progress. Install with
# integrations/install-nautilus.sh, or copy into your file manager's scripts dir:
#   Nautilus/GNOME Files: ~/.local/share/nautilus/scripts/
#   Nemo (Cinnamon/Mint): ~/.local/share/nemo/scripts/
#   Caja (MATE):          ~/.config/caja/scripts/
#
# Optional overrides (else ImageArc uses ~/.config/imagearc/config.json):
#   IMAGEARC_MODEL=qwen3-vl  IMAGEARC_PROVIDER=ollama  IMAGEARC_BIN=/path/to/imagearc
set -u

MODEL="${IMAGEARC_MODEL:-}"
PROVIDER="${IMAGEARC_PROVIDER:-}"
BIN="${IMAGEARC_BIN:-imagearc}"

sel="${NAUTILUS_SCRIPT_SELECTED_FILE_PATHS:-${NEMO_SCRIPT_SELECTED_FILE_PATHS:-${CAJA_SCRIPT_SELECTED_FILE_PATHS:-}}}"

notify() { if command -v notify-send >/dev/null 2>&1; then notify-send "ImageArc" "$1"; else echo "$1"; fi; }

if ! command -v "$BIN" >/dev/null 2>&1; then
  notify "imagearc not found on PATH — install it or set IMAGEARC_BIN."
  exit 1
fi
[ -n "$sel" ] || { notify "Nothing selected."; exit 0; }

args=()
[ -n "$MODEL" ]    && args+=(--model "$MODEL")
[ -n "$PROVIDER" ] && args+=(--provider "$PROVIDER")

# Build a self-contained runner with the selection + args baked in (safely
# quoted), so we don't fight terminal argument/quoting rules.
runner="$(mktemp -t imagearc-run-XXXXXX.sh)"
{
  printf '#!/usr/bin/env bash\nset -u\n'
  printf 'BIN=%q\n' "$BIN"
  printf 'ARGS=('; for a in "${args[@]}"; do printf '%q ' "$a"; done; printf ')\n'
  printf 'SEL=('; while IFS= read -r p; do [ -n "$p" ] && printf '%q ' "$p"; done <<< "$sel"; printf ')\n'
  cat <<'EOS'
errs=0; n=${#SEL[@]}; i=0
echo "ImageArc — captioning $n item(s). Close this window to stop."
for p in "${SEL[@]}"; do
  i=$((i+1)); rec=(); [ -d "$p" ] && rec=(--recurse)
  echo; echo "──[ $i/$n ]────────── $p"
  "$BIN" caption "${ARGS[@]}" "${rec[@]}" "$p" || errs=$((errs+1))
done
echo
if [ "$errs" -eq 0 ]; then
  echo "✓ Done. In Shotwell: Preferences → write metadata to files, then re-import to see tags."
else
  echo "✗ Finished with $errs error(s) above."
fi
command -v notify-send >/dev/null 2>&1 && notify-send "ImageArc" "Captioning finished ($errs error(s))."
# Pause so the window stays open in a terminal; no-op when run headless (no tty).
read -n1 -rsp "Press any key to close… " _ 2>/dev/null || true
echo
rm -f -- "$0"
EOS
} > "$runner"
chmod +x "$runner"

# Open a terminal so progress is visible; fall back to headless + notifications.
if command -v gnome-terminal >/dev/null 2>&1; then
  gnome-terminal --title="ImageArc" -- bash "$runner"
elif command -v konsole >/dev/null 2>&1; then
  konsole -e bash "$runner"
elif command -v xfce4-terminal >/dev/null 2>&1; then
  xfce4-terminal -x bash "$runner"
elif command -v mate-terminal >/dev/null 2>&1; then
  mate-terminal -e "bash '$runner'"
elif command -v xterm >/dev/null 2>&1; then
  xterm -e bash "$runner"
elif command -v x-terminal-emulator >/dev/null 2>&1; then
  x-terminal-emulator -e bash "$runner"
else
  notify "Captioning started (no terminal found; running in background)…"
  bash "$runner"
fi
